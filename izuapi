#!/bin/bash
# izuapi - Start Miruro API server for izu-cli

set -e

API_PORT="${API_PORT:-8000}"
API_DIR="$HOME/.local/share/izu-cli/miruro-api"
VENV_DIR="$API_DIR/venv"

usage() {
    echo "izuapi - Miruro API server for izu-cli"
    echo ""
    echo "Usage: izuapi [command]"
    echo ""
    echo "Commands:"
    echo "  start     Start the API server (default)"
    echo "  stop      Stop the API server"
    echo "  restart   Restart the API server"
    echo "  status    Check if API is running"
    echo "  logs      View API logs"
    echo "  setup     First-time setup (clone & install)"
    echo "  update    Update to latest version"
    echo ""
    echo "Options:"
    echo "  --port    Set API port (default: 8000)"
    echo "  --help    Show this help"
}

check_python() {
    if ! command -v python3 &> /dev/null; then
        echo "Error: Python 3 is not installed"
        echo "Install Python: https://www.python.org/"
        exit 1
    fi
}

setup() {
    check_python

    echo "Setting up Miruro API..."

    # Clone repo if not exists
    if [ ! -d "$API_DIR" ]; then
        echo "Cloning Miruro API repository..."
        mkdir -p "$(dirname "$API_DIR")"
        git clone --depth 1 https://github.com/walterwhite-69/Miruro-API.git "$API_DIR"
    fi

    cd "$API_DIR"

    # Create venv if not exists
    if [ ! -d "$VENV_DIR" ]; then
        echo "Creating Python virtual environment..."
        python3 -m venv venv
    fi

    echo "Installing dependencies..."
    source "$VENV_DIR/bin/activate"
    pip install -r requirements.txt

    echo ""
    echo "Setup complete!"
    echo "Run 'izuapi start' to start the API."
}

start() {
    check_python

    if [ ! -d "$VENV_DIR" ]; then
        echo "API not installed. Running setup first..."
        setup
    fi

    cd "$API_DIR"

    # Check if already running
    if [ -f /tmp/miruro-api.pid ] && kill -0 $(cat /tmp/miruro-api.pid) 2>/dev/null; then
        echo "API is already running on port $API_PORT"
        echo "Stop it first with: izuapi stop"
        exit 1
    fi

    echo "Starting Miruro API on port $API_PORT..."

    # Start the API server in background
    source "$VENV_DIR/bin/activate"
    nohup uvicorn api:app --host 0.0.0.0 --port "$API_PORT" > /tmp/miruro-api.log 2>&1 &
    echo $! > /tmp/miruro-api.pid
    disown

    # Wait and check if started
    sleep 3

    if kill -0 $(cat /tmp/miruro-api.pid) 2>/dev/null; then
        echo "API started successfully!"
        echo ""
        echo "URL: http://localhost:$API_PORT"
        echo ""
        echo "izu-cli is configured to use this API."
    else
        echo "Error: Failed to start API"
        echo "Check logs: izuapi logs"
        exit 1
    fi
}

stop() {
    if [ -f /tmp/miruro-api.pid ]; then
        PID=$(cat /tmp/miruro-api.pid)
        if kill -0 $PID 2>/dev/null; then
            echo "Stopping API (PID: $PID)..."
            kill $PID
            rm /tmp/miruro-api.pid
            echo "API stopped."
        else
            echo "API is not running (stale PID file)"
            rm /tmp/miruro-api.pid
        fi
    else
        echo "API is not running"
    fi
}

status() {
    if [ -f /tmp/miruro-api.pid ] && kill -0 $(cat /tmp/miruro-api.pid) 2>/dev/null; then
        echo "API is running"
        echo "PID: $(cat /tmp/miruro-api.pid)"
        echo "URL: http://localhost:$API_PORT"
    else
        echo "API is not running"
        echo "Start with: izuapi start"
    fi
}

logs() {
    if [ -f /tmp/miruro-api.log ]; then
        tail -f /tmp/miruro-api.log
    else
        echo "No logs found"
    fi
}

update() {
    if [ ! -d "$API_DIR" ]; then
        echo "API not installed. Running setup first..."
        setup
        return
    fi

    echo "Updating Miruro API..."
    cd "$API_DIR"
    git pull
    source "$VENV_DIR/bin/activate"
    pip install -r requirements.txt
    echo "Update complete!"
    echo "Restart with: izuapi restart"
}

# Parse arguments
case "${1:-start}" in
    start)
        start
        ;;
    stop)
        stop
        ;;
    restart)
        stop
        sleep 1
        start
        ;;
    status)
        status
        ;;
    logs)
        logs
        ;;
    setup)
        setup
        ;;
    update)
        update
        ;;
    --port)
        API_PORT="$2"
        start
        ;;
    --help|-h)
        usage
        ;;
    *)
        echo "Unknown command: $1"
        usage
        exit 1
        ;;
esac
